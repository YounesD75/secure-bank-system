<configuration>
  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{HH:mm:ss.SSS} %-5level %msg%n</pattern>
    </encoder>
  </appender>
  <root level="ERROR"><appender-ref ref="CONSOLE"/></root>
  <logger name="akka" level="INFO" additivity="false"><appender-ref ref="CONSOLE"/></logger>
  <logger name="SecureBankApp" level="DEBUG" additivity="false"><appender-ref ref="CONSOLE"/></logger>
</configuration>
